{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "lib": ["esnext"],
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "paths": {
      "@/*": ["./ui/src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["tmp-scripts/**/*.ts"]
}
